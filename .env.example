SIGNAL_ALERTS_ENABLED=true
SIGNAL_ALERTS_INTERVAL_MINUTES=15

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=your-user@example.com
ALERT_EMAIL_TO=your-target@example.com
SMTP_STARTTLS=true
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEF_SCHEDULE_TIMEZONE=Europe/Berlin
BRIEF_SCHEDULE_WEEKDAYS=mon,tue,wed,thu,fri
MORNING_BRIEF_TIME=07:15
EUROPE_OPEN_BRIEF_TIME=08:40
MIDDAY_BRIEF_TIME=12:30
US_OPEN_BRIEF_TIME=15:10
CLOSE_RECAP_TIME=21:45
APP_ACCESS_PASSWORD=change-this-password
APP_SESSION_SECRET=change-this-session-secret
APP_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
APP_LOGIN_MAX_ATTEMPTS=5
APP_LOGIN_LOCKOUT_MINUTES=15
APP_ENV=production
APP_COOKIE_SECURE=true
